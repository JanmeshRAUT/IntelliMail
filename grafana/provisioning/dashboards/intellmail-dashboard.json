{
"title": "IntelliMail - Real-Time Monitoring Dashboard",
"description": "Professional monitoring dashboard for IntelliMail application using Prometheus",
"tags": ["intellmail", "monitoring", "production"],
"timezone": "browser",
"schemaVersion": 38,
"version": 2,
"refresh": "5s",
"time": {
"from": "now-5m",
"to": "now"
},
"panels": [

{
  "id": 1,
  "title": "API Requests (RPS)",
  "type": "timeseries",
  "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
  "targets": [
    {
      "expr": "rate(intellmail_http_requests_total[1m])",
      "legendFormat": "{{method}} {{route}}",
      "refId": "A"
    }
  ],
  "fieldConfig": {
    "defaults": {
      "unit": "reqps"
    }
  }
},

{
  "id": 2,
  "title": "Response Time (p95)",
  "type": "timeseries",
  "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
  "targets": [
    {
      "expr": "histogram_quantile(0.95, rate(intellmail_http_request_duration_seconds_bucket[1m]))",
      "legendFormat": "{{method}} {{route}}",
      "refId": "A"
    }
  ],
  "fieldConfig": {
    "defaults": {
      "unit": "s"
    }
  }
},

{
  "id": 3,
  "title": "Error Rate",
  "type": "stat",
  "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
  "targets": [
    {
      "expr": "rate(intellmail_http_request_errors_total[1m]) or vector(0)",
      "refId": "A"
    }
  ],
  "fieldConfig": {
    "defaults": {
      "color": {
        "mode": "thresholds"
      },
      "thresholds": {
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 1},
          {"color": "red", "value": 5}
        ]
      }
    }
  }
},

{
  "id": 4,
  "title": "Status Code Distribution",
  "type": "piechart",
  "gridPos": {"h": 8, "w": 12, "x": 6, "y": 8},
  "targets": [
    {
      "expr": "sum(rate(intellmail_http_requests_total[1m])) by (status_code)",
      "legendFormat": "{{status_code}}",
      "refId": "A"
    }
  }
},

{
  "id": 5,
  "title": "CPU Utilization (%)",
  "type": "gauge",
  "gridPos": {"h": 8, "w": 6, "x": 0, "y": 16},
  "targets": [
    {
      "expr": "rate(intellmail_process_cpu_seconds_total[1m]) * 100",
      "refId": "A"
    }
  ],
  "fieldConfig": {
    "defaults": {
      "unit": "percent",
      "thresholds": {
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 60},
          {"color": "red", "value": 80}
        ]
      }
    }
  }
},

{
  "id": 6,
  "title": "Memory Usage (MB)",
  "type": "gauge",
  "gridPos": {"h": 8, "w": 6, "x": 6, "y": 16},
  "targets": [
    {
      "expr": "intellmail_process_resident_memory_bytes / 1024 / 1024",
      "refId": "A"
    }
  ],
  "fieldConfig": {
    "defaults": {
      "unit": "decbytes",
      "thresholds": {
        "steps": [
          {"color": "green", "value": null},
          {"color": "yellow", "value": 200},
          {"color": "red", "value": 400}
        ]
      }
    }
  }
}
  ]
}
