{
  "title": "IntelliMail Application Metrics",
  "description": "Application monitoring dashboard for IntelliMail",
  "tags": ["intellmail", "application", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "uid": "intellmail-metrics",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests Total",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(intellmail_http_requests_total[5m])",
            "legendFormat": "{{method}} {{route}}",
            "refId": "A",
            "datasource": "Prometheus"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 2,
        "title": "HTTP Request Duration (p95)",
        "type": "graph",
        "datasource": "Prometheus",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(intellmail_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{method}} {{route}}",
            "refId": "A",
            "datasource": "Prometheus"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 3,
        "title": "HTTP Error Rate",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(intellmail_http_request_errors_total[5m])",
            "refId": "A",
            "datasource": "Prometheus"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        }
      },
      {
        "id": 4,
        "title": "Response Status Codes",
        "type": "piechart",
        "datasource": "Prometheus",
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(intellmail_http_requests_total[5m])) by (status_code)",
            "legendFormat": "{{status_code}}",
            "refId": "A",
            "datasource": "Prometheus"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "right"
          },
          "pieType": "donut"
        }
      },
      {
        "id": 5,
        "title": "CPU Usage",
        "type": "graph",
        "datasource": "Prometheus",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "rate(intellmail_process_cpu_seconds_total[5m])",
            "refId": "A",
            "datasource": "Prometheus"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 6,
        "title": "Memory Usage (MB)",
        "type": "graph",
        "datasource": "Prometheus",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "intellmail_process_resident_memory_bytes / 1024 / 1024",
            "refId": "A",
            "datasource": "Prometheus"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          },
          "unit": "decmbytes"
        }
    }
  ],
  "templating": {
    "list": []
  }
}
