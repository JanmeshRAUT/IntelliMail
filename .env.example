# Frontend Configuration
PORT=3000
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_from_gcp_console

# Hugging Face API Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key
HUGGINGFACE_URL_MODEL=JerryJR1705/ThreadDetection
HUGGINGFACE_EMAIL_MODEL=JerryJR1705/ThreadDetection

# ML Backend Services (Hosted on Hugging Face Spaces)
# These URLs point to your ML models deployed on HF Spaces
ML_SERVICE_URL=https://JerryJR1705-intellmail.hf.space
VITE_ML_SERVICE_URL=https://JerryJR1705-intellmail.hf.space/
LSTM_SERVICE_URL=https://JerryJR1705-intellmail.hf.space/
VITE_LSTM_SERVICE_URL=https://JerryJR1705-intellmail.hf.space

# MongoDB Atlas Configuration
DATABASEURL=mongodb+srv://your_username:your_password@cluster.mongodb.net/?appName=Cluster0
MONGO_USER=your_mongo_username
MONGO_PASSWORD=your_mongo_password

# Environment
NODE_ENV=production

# App URL (for Vercel)
APP_URL=https://your-app.vercel.app
