# APP_URL: The URL where this applet is hosted.
APP_URL=

# Google OAuth Web Client ID used by frontend build/runtime.
VITE_GOOGLE_CLIENT_ID=

# ============================================================
# HUGGINGFACE INFERENCE API (Replaces Python ML Services!)
# ============================================================
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_hf_token_here

# Your HuggingFace model repository (already uploaded!)
HUGGINGFACE_URL_MODEL=JerryJR1705/ThreadDetection
HUGGINGFACE_EMAIL_MODEL=JerryJR1705/ThreadDetection
