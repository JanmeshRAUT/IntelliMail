# Frontend Configuration
PORT=3000
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_from_gcp_console

# Hugging Face API Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key
VITE_HUGGINGFACE_API_KEY=your_huggingface_api_key

HUGGINGFACE_URL_MODEL=update_with_your_url_model_on_hf_space
HUGGINGFACE_EMAIL_MODEL=update_with_your_email_model_on_hf_space

# ML Backend Services (Hosted on Hugging Face Spaces)
# These URLs point to your ML models deployed on HF Spaces
ML_SERVICE_URL=upload_url_to_your_ml_model_on_hf_space
VITE_ML_SERVICE_URL=upload_url_to_your_ml_model_on_hf_space
LSTM_SERVICE_URL=upload_url_to_your_lstm_model_on_hf_space
VITE_LSTM_SERVICE_URL=upload_url_to_your_lstm_model_on_hf_space

# MongoDB Atlas Configuration
DATABASEURL=url_to_your_mongodb_atlas_cluster
MONGO_USER=your_mongo_username
MONGO_PASSWORD=your_mongo_password

# Environment
NODE_ENV=production

# App URL (for Vercel)
APP_URL=https://your-app.vercel.app
