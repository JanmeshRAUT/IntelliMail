{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",

    "outDir": "dist",
    "rootDir": ".",

    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    "isolatedModules": false,
    "allowJs": true,
    "jsx": "react-jsx",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server.ts"]
}